/* =========================================================
   TellMe Terminal UI — Global Stylesheet
   All values hydrated from Python design tokens at runtime.
   ========================================================= */

/* --- RESET --- */
* {
    font-family: "{FAMILY_PRIMARY}";
    color: {TEXT_PRIMARY};
    outline: none;
    selection-background-color: {SELECTION};
    selection-color: {TEXT_PRIMARY};
}

/* --- ROOT BACKGROUNDS --- */
QMainWindow, QWidget {
    background-color: {BACKGROUND};
    border: none;
}

QStackedWidget {
    background-color: {BACKGROUND};
}

/* --- SCROLLBARS (thin, terminal style) --- */
QScrollBar:vertical {
    background: {BACKGROUND};
    width: 8px;
    border: none;
}
QScrollBar::handle:vertical {
    background: {BORDER};
    min-height: 20px;
}
QScrollBar::handle:vertical:hover {
    background: {PRIMARY_DIM};
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}
QScrollBar:horizontal {
    background: {BACKGROUND};
    height: 8px;
    border: none;
}
QScrollBar::handle:horizontal {
    background: {BORDER};
    min-width: 20px;
}
QScrollBar::handle:horizontal:hover {
    background: {PRIMARY_DIM};
}
QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

/* --- SIDEBAR --- */
QWidget#terminalSidebar {
    background-color: {BACKGROUND};
    border-right: 1px solid {BORDER};
}

QPushButton#sidebarButton {
    background-color: transparent;
    border: none;
    border-left: 2px solid transparent;
    text-align: left;
    padding: 6px 8px 6px 12px;
    font-size: {SIZE_BODY};
    color: {TEXT_MUTED};
    font-family: "{FAMILY_PRIMARY}";
}
QPushButton#sidebarButton:hover {
    background-color: {SURFACE_HOVER};
    color: {TEXT_PRIMARY};
    border-left: 2px solid {BORDER};
}
QPushButton#sidebarButton:checked {
    background-color: {SURFACE_HOVER};
    color: {TEXT_PRIMARY};
    border-left: 2px solid {PRIMARY};
}

/* --- STATUS BAR --- */
QWidget#terminalStatusBar {
    background-color: {BACKGROUND};
    border-top: 1px solid {BORDER};
}
QLabel#statusBarLabel {
    color: {TEXT_MUTED};
    font-size: {SIZE_CAPTION};
    padding: 0 8px;
}
QLabel#statusBarLabelPrimary {
    color: {TEXT_PRIMARY};
    font-size: {SIZE_CAPTION};
    padding: 0 8px;
}

/* --- TOP BAR --- */
QWidget#terminalTopBar {
    background-color: {BACKGROUND};
    border-bottom: 1px solid {BORDER};
}
QLabel#topBarLabel {
    color: {TEXT_MUTED};
    font-size: {SIZE_CAPTION};
    padding: 0 8px;
}

/* --- TERMINAL WINDOW / PANEL --- */
QWidget#terminalWindow {
    background-color: {SURFACE};
    border: 1px solid {BORDER};
}
QLabel#terminalWindowTitle {
    background-color: {BORDER};
    color: {TEXT_PRIMARY};
    font-size: {SIZE_SMALL};
    padding: 2px 8px;
    font-family: "{FAMILY_PRIMARY}";
}

/* --- TERMINAL BUTTONS --- */
QPushButton#terminalButton {
    background-color: {BACKGROUND};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    padding: 4px 12px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    min-height: 24px;
}
QPushButton#terminalButton:hover {
    background-color: {PRIMARY};
    color: {TEXT_INVERSE};
    border: 1px solid {PRIMARY};
}
QPushButton#terminalButton:pressed {
    padding-top: 5px;
    padding-bottom: 3px;
}
QPushButton#terminalButton:disabled {
    color: {TEXT_DISABLED};
    border: 1px solid {BORDER_DIM};
    background-color: {BACKGROUND};
}

QPushButton#terminalButtonDanger {
    background-color: {BACKGROUND};
    color: {DANGER};
    border: 1px solid {DANGER};
    padding: 4px 12px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    min-height: 24px;
}
QPushButton#terminalButtonDanger:hover {
    background-color: {DANGER};
    color: {BACKGROUND};
}

QPushButton#terminalButtonWarning {
    background-color: {BACKGROUND};
    color: {WARNING};
    border: 1px solid {WARNING};
    padding: 4px 12px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    min-height: 24px;
}
QPushButton#terminalButtonWarning:hover {
    background-color: {WARNING};
    color: {BACKGROUND};
}

/* --- TERMINAL INPUTS --- */
QLineEdit#terminalInput {
    background-color: {BACKGROUND};
    color: {TEXT_PRIMARY};
    border: none;
    border-bottom: 1px solid {BORDER};
    padding: 4px 4px 4px 0px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    selection-background-color: {SELECTION};
}
QLineEdit#terminalInput:focus {
    border-bottom: 1px solid {PRIMARY};
}

QTextEdit#terminalTextEdit {
    background-color: {BACKGROUND};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    padding: 8px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    selection-background-color: {SELECTION};
}

/* --- LABELS --- */
QLabel {
    background-color: transparent;
    color: {TEXT_PRIMARY};
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
}
QLabel#labelMuted {
    color: {TEXT_MUTED};
    font-size: {SIZE_SMALL};
}
QLabel#labelSecondary {
    color: {TEXT_SECONDARY};
    font-size: {SIZE_BODY};
}
QLabel#labelDanger {
    color: {DANGER};
    font-size: {SIZE_SMALL};
}
QLabel#labelSuccess {
    color: {SUCCESS};
    font-size: {SIZE_SMALL};
}
QLabel#labelWarning {
    color: {WARNING};
    font-size: {SIZE_SMALL};
}
QLabel#sectionHeader {
    color: {TEXT_PRIMARY};
    font-size: {SIZE_BODY};
    font-weight: bold;
    padding: 2px 0px;
}

/* --- LIST / TABLE --- */
QListWidget, QTreeWidget, QTableWidget {
    background-color: {BACKGROUND};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    gridline-color: {BORDER};
    outline: none;
}
QListWidget::item, QTreeWidget::item, QTableWidget::item {
    padding: 4px 8px;
    border: none;
}
QListWidget::item:hover, QTreeWidget::item:hover, QTableWidget::item:hover {
    background-color: {SURFACE_HOVER};
    color: {TEXT_PRIMARY};
}
QListWidget::item:selected, QTreeWidget::item:selected, QTableWidget::item:selected {
    background-color: {SELECTION};
    color: {TEXT_PRIMARY};
}
QHeaderView::section {
    background-color: {SURFACE};
    color: {TEXT_MUTED};
    border: none;
    border-right: 1px solid {BORDER};
    border-bottom: 1px solid {BORDER};
    padding: 4px 8px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_SMALL};
}

/* --- COMBO BOX --- */
QComboBox#terminalCombo {
    background-color: {BACKGROUND};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    padding: 3px 8px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    min-height: 24px;
}
QComboBox#terminalCombo:hover {
    border: 1px solid {PRIMARY_DIM};
}
QComboBox#terminalCombo::drop-down {
    border: none;
    width: 20px;
}
QComboBox#terminalCombo::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid {TEXT_SECONDARY};
    width: 0;
    height: 0;
}
QComboBox QAbstractItemView {
    background-color: {SURFACE};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    selection-background-color: {SELECTION};
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    outline: none;
}

/* --- CHECKBOX / RADIO --- */
QCheckBox {
    color: {TEXT_SECONDARY};
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
    spacing: 8px;
}
QCheckBox::indicator {
    width: 12px;
    height: 12px;
    border: 1px solid {BORDER};
    background-color: {BACKGROUND};
}
QCheckBox::indicator:checked {
    background-color: {PRIMARY};
    border: 1px solid {PRIMARY};
}
QCheckBox::indicator:hover {
    border: 1px solid {PRIMARY_DIM};
}

/* --- SLIDER --- */
QSlider::groove:horizontal {
    height: 2px;
    background: {BORDER};
}
QSlider::handle:horizontal {
    background: {PRIMARY};
    width: 10px;
    height: 10px;
    margin: -4px 0;
}
QSlider::sub-page:horizontal {
    background: {PRIMARY_DIM};
}

/* --- SPLITTER --- */
QSplitter::handle {
    background: {BORDER};
}
QSplitter::handle:horizontal {
    width: 1px;
}
QSplitter::handle:vertical {
    height: 1px;
}

/* --- TOOLTIP --- */
QToolTip {
    background-color: {SURFACE};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_SMALL};
    padding: 4px 8px;
}

/* --- MENU --- */
QMenu {
    background-color: {SURFACE};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
}
QMenu::item:selected {
    background-color: {SELECTION};
}
QMenu::separator {
    height: 1px;
    background: {BORDER};
    margin: 2px 0;
}

/* --- TAB BAR --- */
QTabBar {
    background-color: {BACKGROUND};
}
QTabBar::tab {
    background-color: {BACKGROUND};
    color: {TEXT_MUTED};
    border: none;
    border-right: 1px solid {BORDER};
    padding: 4px 16px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_SMALL};
}
QTabBar::tab:selected {
    color: {TEXT_PRIMARY};
    border-bottom: 2px solid {PRIMARY};
}
QTabBar::tab:hover {
    background-color: {SURFACE_HOVER};
    color: {TEXT_SECONDARY};
}
QTabWidget::pane {
    border: 1px solid {BORDER};
    top: -1px;
}

/* --- PROGRESS BAR --- */
QProgressBar {
    background-color: {BACKGROUND};
    border: 1px solid {BORDER};
    text-align: center;
    color: {TEXT_PRIMARY};
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_SMALL};
    max-height: 8px;
}
QProgressBar::chunk {
    background-color: {PRIMARY};
}

/* --- DIALOG / MESSAGEBOX --- */
QDialog {
    background-color: {BACKGROUND};
    border: 1px solid {BORDER};
    color: {TEXT_PRIMARY};
    font-family: "{FAMILY_PRIMARY}";
}
QMessageBox {
    background-color: {BACKGROUND};
    color: {TEXT_PRIMARY};
    font-family: "{FAMILY_PRIMARY}";
}

/* --- SPINBOX --- */
QSpinBox, QDoubleSpinBox {
    background-color: {BACKGROUND};
    color: {TEXT_PRIMARY};
    border: 1px solid {BORDER};
    padding: 2px 4px;
    font-family: "{FAMILY_PRIMARY}";
    font-size: {SIZE_BODY};
}
QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid {PRIMARY_DIM};
}
QSpinBox::up-button, QSpinBox::down-button,
QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    width: 16px;
    background-color: {SURFACE};
    border-left: 1px solid {BORDER};
}
