# TellMe Environment Configuration
# Copy this file to .env and fill in appropriate values.
# Never commit .env to version control.

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
APP_NAME=TellMe
APP_VERSION=0.1.0
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# Runtime Paths (override if needed)
# These default to the `runtime/` folder relative to the project root.
# ─────────────────────────────────────────────
RUNTIME_CACHE_DIR=runtime/cache
RUNTIME_LOGS_DIR=runtime/logs
RUNTIME_TEMP_DIR=runtime/temp
RUNTIME_SESSIONS_DIR=runtime/sessions

# ─────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────
DATABASE_URL=sqlite:///runtime/tellme.db

# ─────────────────────────────────────────────
# LLM Provider (set by user at runtime via Settings UI)
# Leave blank — model path is registered through the model management system.
# ─────────────────────────────────────────────
ACTIVE_LLM_BACKEND=llamacpp
# ACTIVE_MODEL_ID=

# ─────────────────────────────────────────────
# Speech Provider
# ─────────────────────────────────────────────
ACTIVE_STT_BACKEND=whisper
ACTIVE_TTS_BACKEND=piper

# ─────────────────────────────────────────────
# Search Provider (optional)
# ─────────────────────────────────────────────
SEARCH_ENABLED=false
# SEARCH_BACKEND=duckduckgo

# ─────────────────────────────────────────────
# Plugin System
# ─────────────────────────────────────────────
PLUGINS_ENABLED=false
# PLUGINS_DIR=plugins/
